{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MaTE",
  "version": "0.1.0",
  "identifier": "se.kungsbacka.mate",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "node frontend/build.js",
    "beforeBuildCommand": "node frontend/build.js"
  },
  "app": {
    "windows": [
      {
        "title": "MaTE",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
